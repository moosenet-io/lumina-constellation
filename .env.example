# =============================================================================
# Lumina Constellation — Environment Configuration (EXAMPLE)
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file to `.env`:   cp .env.example .env
#   2. Fill in the values for your own infrastructure.
#   3. Start the services (see docs/deployment.md).
#
# SECRETS:
#   The fields marked `<set-in-vault>` (passwords, tokens, JWT secrets, API
#   keys) are sensitive. In production, DO NOT store real secrets in `.env`.
#   Resolve them at runtime from the encrypted vault — every secret key is read
#   from the vault first and only falls back to the environment. Use `.env`
#   secrets for local development only, and never commit a filled-in `.env`
#   (`.gitignore` excludes `.env` and `.env.*`, allowing only this example).
#
# PLACEHOLDERS:
#   All values below are placeholders. Replace `localhost` / `127.0.0.1` ports
#   and `*.example.org` hosts with your real addresses. This file ships with NO
#   real infrastructure details.
#
# This file mirrors the "Configuration reference" table in docs/deployment.md.
# Defaults shown in the docs apply when a variable is left unset.
# =============================================================================


# -----------------------------------------------------------------------------
# Core orchestrator (lumina-core)
# -----------------------------------------------------------------------------

# Address the orchestrator's HTTP interface binds to.
LUMINA_HTTP_BIND=127.0.0.1:8080
# Bearer token protecting the orchestrator's HTTP interface. (secret)
LUMINA_HTTP_TOKEN=<set-in-vault>
# Persona / system prompt for the assistant. Leave unset to use the built-in default.
LUMINA_SYSTEM_PROMPT=
# Matrix ID of the operator/admin (auto-promoted to Admin on first contact).
LUMINA_ADMIN_MATRIX_ID=@operator:example.org
# Comma-separated allowlist of outbound hosts tools may reach.
# Must include the Chord proxy, tool hub, Matrix homeserver, and any tool APIs.
LUMINA_EGRESS_ALLOWLIST=example.com,api.example.net
# Idle timeout (seconds) before a conversation session is closed.
LUMINA_SESSION_TIMEOUT_SECS=1800
# Idle window (minutes) for session bookkeeping.
SESSION_IDLE_MINUTES=30
# Number of recent turns kept verbatim in working memory.
CONVERSATION_WINDOW=20

# --- Conversation memory ---
# Enable the in-memory working-memory buffer.
LUMINA_CONV_BUFFER_ENABLED=true
# Max turns held in the buffer.
LUMINA_CONV_BUFFER_SIZE=20
# Token budget before older turns are summarized/evicted.
LUMINA_CONV_TOKEN_BUDGET=4000
# Summarize (rather than drop) overflow turns.
LUMINA_CONV_SUMMARIZE_ENABLED=true
# Token threshold that triggers summarization.
LUMINA_CONV_SUMMARIZE_THRESHOLD=3000
# Fast local model used to summarize (must NOT be the personality model).
LUMINA_CONV_SUMMARIZE_MODEL=qwen3:8b
# Endpoint for the summarization model (defaults to OLLAMA_CPU_URL/OLLAMA_URL if unset).
LUMINA_CONV_SUMMARIZE_URL=http://localhost:11434

# --- Memory store (Engram) ---
# Embedding model for semantic memory.
ENGRAM_EMBED_MODEL=nomic-embed-text
# Endpoint serving the embedding model.
OLLAMA_EMBEDDING_URL=http://localhost:11434


# -----------------------------------------------------------------------------
# Chat channel (Matrix)
# -----------------------------------------------------------------------------

# Homeserver URL.
MATRIX_HOMESERVER=https://matrix.example.org
# Bot account user ID.
MATRIX_USER=@assistant:example.org
# Bot account password. (secret)
MATRIX_PASSWORD=<set-in-vault>
# Room the assistant operates in.
MATRIX_ROOM_ID=!room:example.org
# Comma-separated allowlist of Matrix users who may talk to the bot.
# Empty = allow all (backward-compatible default).
MATRIX_ALLOWED_USERS=@operator:example.org
# Local path for the Matrix client store.
MATRIX_STORE_PATH=./data/matrix


# -----------------------------------------------------------------------------
# Inference proxy (chord-proxy)
# -----------------------------------------------------------------------------

# Inference/proxy listener port.
CHORD_PROXY_PORT=8099
# URL clients (lumina-core) use to reach the proxy. (required)
CHORD_PROXY_URL=http://localhost:8099
# Shared secret lumina-core presents to the proxy. (secret)
LUMINA_CHORD_SECRET=<set-in-vault>
# Separate control-API listener port (model-tier management).
CHORD_CONTROL_PORT=8090
# HS256 signing secret for proxy/control auth (random 32 bytes). (secret)
CHORD_JWT_SECRET=<set-in-vault>
# Backend inference endpoint (local Ollama). Empty disables /v1/chat/completions (503).
CHORD_LLM_URL=http://localhost:11434
# Friendly model aliases mapped to concrete models (JSON object).
CHORD_MODEL_ALIASES={"lumina-fast":"qwen3:8b","lumina-deep":"gpt-oss:120b"}
# Enable the agentic tool-calling loop.
CHORD_AGENTIC_MODE=true
# Per-tool-call timeout (seconds).
CHORD_TOOL_TIMEOUT_SECS=30
# Tool-catalog cache TTL (seconds).
CHORD_CATALOG_CACHE_SECS=60
# Per-user / per-guest LLM rate limits (daily call counts).
CHORD_RATE_LLM_USER=200
CHORD_RATE_LLM_GUEST=20
# Per-user / per-guest tool-call rate limits.
CHORD_RATE_TOOL_USER=500
CHORD_RATE_TOOL_GUEST=50
# Per-user / per-guest deep-reasoning rate limits.
CHORD_RATE_DEEP_USER=50
CHORD_RATE_DEEP_GUEST=5


# -----------------------------------------------------------------------------
# Local inference backends (Ollama)
# -----------------------------------------------------------------------------

# Primary (GPU) Ollama endpoint.
OLLAMA_URL=http://localhost:11434
# Optional CPU-only Ollama endpoint for overflow / summarization.
OLLAMA_CPU_URL=http://localhost:11435


# -----------------------------------------------------------------------------
# Tool hub (terminus-rs)
# -----------------------------------------------------------------------------

# Tool-hub address used by lumina-core.
TERMINUS_HOST=http://localhost:8083
# Backend the proxy dispatches MCP tool calls to.
MCP_BACKEND_URL=http://localhost:8083
# Max tool calls per agentic turn.
MCP_MAX_TOOL_CALLS=8


# -----------------------------------------------------------------------------
# Model storage tiers
# -----------------------------------------------------------------------------

# Where model-tier state (tier/size/timestamps) is recorded.
MODEL_REGISTRY_PATH=./data/model-registry.json
# Warm tier — local model directory.
MODEL_LOCAL_PATH=/var/lib/ollama/models
# Cold tier — archive directory (e.g. network storage).
MODEL_ARCHIVE_PATH=/mnt/archive/models
# Comma-separated models never auto-archived.
MODEL_PROTECTED=qwen3:8b,nomic-embed-text
# Disk-usage percentage that triggers eviction (warm -> cold).
MODEL_DISK_PRESSURE_PERCENT=80
# Idle hours before a warm model is archived (0 disables cooldown eviction).
MODEL_WARM_COOLDOWN_HOURS=168
# Background eviction-sweep interval (seconds).
MODEL_SWEEP_INTERVAL_SECS=1800
# Timeout when pulling a cold model back to warm (seconds).
MODEL_PULL_TIMEOUT_SECS=600
