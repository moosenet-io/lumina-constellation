# Lumina Constellation — Environment Configuration
# Copy to .env and fill in your values
# Run: cp deploy/.env.example deploy/.env

# ── Required ──────────────────────────────────────────────────────────────────

# Ollama location (where your models run)
# Docker Desktop (Mac/Windows):  http://host.docker.internal:11434
# Linux native Docker:           http://YOUR_PRIVATE_HOST_IP:11434
# Remote GPU box:                http://YOUR_GPU_BOX_IP:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Database
POSTGRES_PASSWORD=change-me-strong-password

# Soma dashboard keys (generate with: openssl rand -hex 32)
SOMA_SECRET_KEY=
SOMA_JWT_SECRET=

# LiteLLM proxy master key (generate with: openssl rand -hex 32)
LITELLM_MASTER_KEY=

# ── Optional (cloud fallback inference) ───────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional (integrations) ───────────────────────────────────────────────────
GITEA_URL=
GITEA_TOKEN=
PLANE_BASE_URL=
PLANE_TOKEN_LUMINA=
TOMTOM_API_KEY=
NEWSAPI_KEY=

# ── Optional (Matrix messaging) ───────────────────────────────────────────────
MATRIX_SERVER_NAME=lumina.local
IRONCLAW_URL=
IRONCLAW_GATEWAY_TOKEN=

# ── Optional (ports) ──────────────────────────────────────────────────────────
SOMA_PORT=8082
LITELLM_PORT=4000
TERMINUS_PORT=8083
SPECTRA_PORT=8084
SPECTRA_INTERNAL_PORT=8085
POSTGRES_PORT=5432

# ── Optional (timezone + locale) ──────────────────────────────────────────────
LUMINA_TIMEZONE=America/Los_Angeles

# ── Optional (Caddy TLS) ──────────────────────────────────────────────────────
# Leave as localhost for local-only access
# Set to your domain (e.g., lumina.yourhome.net) for TLS via Caddy
CADDY_DOMAIN=localhost

# ── Optional (Spectra browser agent) ──────────────────────────────────────────
SPECTRA_OPERATOR_KEY=spectra-operator-dev
