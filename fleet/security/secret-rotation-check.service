[Unit]
Description=Lumina Secret Rotation Check (SEC.12)
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/lumina-fleet/security
EnvironmentFile=-/opt/lumina-fleet/axon/.env
ExecStart=/usr/bin/python3 /opt/lumina-fleet/security/rotation.py run
StandardOutput=journal
StandardError=journal
SyslogIdentifier=lumina-secret-rotation
