#!/usr/bin/env python3
"""
lumina-secrets — CLI for Lumina secret rotation management (SEC.11)

Usage:
  lumina-secrets list              — Show all secrets with status
  lumina-secrets check             — Exit 1 if any expired/warn, print summary
  lumina-secrets rotate <name>     — Force-rotate a specific secret
  lumina-secrets run               — Rotate all expired secrets
  lumina-secrets run --dry-run     — Preview what would be rotated

Install: chmod +x lumina-secrets && ln -sf /opt/lumina-fleet/security/lumina-secrets /usr/local/bin/lumina-secrets
"""

import json
import sys
import os
from pathlib import Path

_FLEET_DIR = Path(os.environ.get('FLEET_DIR', '/opt/lumina-fleet'))
sys.path.insert(0, str(_FLEET_DIR / 'security'))

try:
    import rotation
except ImportError as e:
    print(f'ERROR: Cannot import rotation module: {e}')
    print(f'Expected at: {_FLEET_DIR}/security/rotation.py')
    sys.exit(2)

# ANSI colors (disabled if not a TTY)
_tty = sys.stdout.isatty()
def _c(code, text): return f'\033[{code}m{text}\033[0m' if _tty else text
def _green(t): return _c('32', t)
def _yellow(t): return _c('33', t)
def _red(t): return _c('31', t)
def _bold(t): return _c('1', t)
def _dim(t): return _c('2', t)


def cmd_list():
    ages = rotation.check_secret_ages()
    if not ages:
        print('No secrets in registry.')
        return

    # Header
    print(_bold(f'{"Secret":<35} {"Status":<10} {"Age":>7} {"Max":>7} {"Remaining":>11}  {"Method":<15} Services'))
    print('─' * 110)

    for s in ages:
        name = s['name']
        status = s['status']
        age_str  = f'{s["age_days"]}d'  if s["age_days"]  is not None else _dim('unknown')
        rem_str  = f'{s["days_remaining"]}d' if s["days_remaining"] is not None else _dim('—')
        max_str  = f'{s["max_age_days"]}d'
        method   = s['method']
        services = ', '.join(s.get('services', [])) or '—'

        status_str = {'ok': _green('OK'), 'warn': _yellow('WARN'), 'expired': _red('EXPIRED'), 'unknown': _dim('?')}.get(status, status)
        # Color remaining based on status
        if status == 'expired':
            rem_str = _red(rem_str)
        elif status == 'warn':
            rem_str = _yellow(rem_str)

        print(f'{name:<35} {status_str:<21} {age_str:>7} {max_str:>7} {rem_str:>22}  {method:<15} {_dim(services)}')

    # Summary
    total = len(ages)
    ok      = sum(1 for s in ages if s['status'] == 'ok')
    warn    = sum(1 for s in ages if s['status'] == 'warn')
    expired = sum(1 for s in ages if s['status'] == 'expired')
    unknown = sum(1 for s in ages if s['status'] == 'unknown')
    print()
    parts = [f'{_green(str(ok))} ok']
    if warn:    parts.append(f'{_yellow(str(warn))} warn')
    if expired: parts.append(f'{_red(str(expired))} expired')
    if unknown: parts.append(f'{_dim(str(unknown))} unknown')
    print(f'{total} secrets: ' + ', '.join(parts))


def cmd_check():
    """Non-interactive check — exit code reflects health."""
    ages = rotation.check_secret_ages()
    expired = [s for s in ages if s['status'] == 'expired']
    warn    = [s for s in ages if s['status'] == 'warn']

    if expired:
        names = ', '.join(s['name'] for s in expired)
        print(f'CRITICAL: {len(expired)} expired secret(s): {names}')
        sys.exit(2)

    if warn:
        names = ', '.join(s['name'] for s in warn)
        print(f'WARNING: {len(warn)} secret(s) expiring soon: {names}')
        sys.exit(1)

    ok = sum(1 for s in ages if s['status'] == 'ok')
    print(f'OK: {ok} secret(s) within rotation window')
    sys.exit(0)


def cmd_rotate(name):
    registry = rotation.load_registry()
    state = rotation._load_state()
    secret = next((s for s in registry if s['name'] == name), None)
    if not secret:
        print(f'ERROR: Secret "{name}" not found in registry.')
        print(f'Available: {", ".join(s["name"] for s in registry)}')
        sys.exit(1)

    print(f'Rotating {name} (method: {secret["method"]})...')
    ok = rotation.rotate_secret(secret, state, force=True)
    rotation._save_state(state)
    if ok:
        print(_green(f'OK: {name} rotated successfully.'))
    else:
        print(_red(f'FAILED: {name} rotation failed. Check logs.'))
        sys.exit(1)


def cmd_run(dry_run=False):
    label = ' (dry run)' if dry_run else ''
    print(f'Running rotation check{label}...')
    summary = rotation.run_all(dry_run=dry_run)
    print()
    if summary['rotated']:
        print(_green(f'Rotated ({len(summary["rotated"])}): ') + ', '.join(summary['rotated']))
    if summary['warned']:
        print(_yellow(f'Warnings ({len(summary["warned"])}): ') + ', '.join(summary['warned']))
    if summary['errors']:
        print(_red(f'Errors ({len(summary["errors"])}): ') + ', '.join(summary['errors']))
    if summary['ok']:
        print(_dim(f'OK ({len(summary["ok"])} secrets): ') + _dim(', '.join(summary['ok'])))
    if summary['errors']:
        sys.exit(1)


def _usage():
    print(__doc__.strip())
    sys.exit(0)


if __name__ == '__main__':
    args = sys.argv[1:]
    if not args or args[0] in ('-h', '--help', 'help'):
        _usage()
    cmd = args[0]
    if cmd == 'list':
        cmd_list()
    elif cmd == 'check':
        cmd_check()
    elif cmd == 'rotate':
        if len(args) < 2:
            print('Usage: lumina-secrets rotate <SECRET_NAME>')
            sys.exit(1)
        cmd_rotate(args[1])
    elif cmd == 'run':
        cmd_run(dry_run='--dry-run' in args)
    else:
        print(f'Unknown command: {cmd}')
        _usage()
