# Axon + Fleet agent environment configuration
# Copy to axon/.env and fill in values from Infisical

INBOX_DB_HOST=YOUR_POSTGRES_IP
INBOX_DB_USER=lumina_inbox_user
INBOX_DB_PASS=<from Infisical: INBOX_DB_PASS>
PLANE_BASE_URL=http://YOUR_PLANE_IP
PLANE_WORKSPACE_SLUG=moosenet
PLANE_TOKEN_LUMINA=<from Infisical: PLANE_TOKEN_LUMINA>
PX_PROJECT_ID=<Plane Plexus project UUID>
GITEA_URL=http://YOUR_GITEA_IP:3000
GITEA_TOKEN=<from Infisical: GITEA_TOKEN>
DASHBOARD_API_KEY=<from Infisical: DASHBOARD_API_KEY>
ALPHAVANTAGE_API_KEY=<from Infisical: ALPHAVANTAGE_API_KEY>
FINNHUB_API_KEY=<from Infisical: FINNHUB_API_KEY>
GOOGLE_LUMINA_EMAIL=<from Infisical: GOOGLE_LUMINA_EMAIL>
GOOGLE_APP_PASSWORD=<from Infisical: GOOGLE_APP_PASSWORD>
LITELLM_MASTER_KEY=<from Infisical: LITELLM_MASTER_KEY>
LITELLM_URL=http://YOUR_LITELLM_IP:4000
SEER_QWEN_MODEL=Lumina Fast
