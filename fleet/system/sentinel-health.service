[Unit]
Description=Sentinel Health Checks (Python, no inference)
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/lumina-fleet/sentinel
EnvironmentFile=/opt/lumina-fleet/axon/.env
ExecStart=/usr/bin/python3 /opt/lumina-fleet/sentinel/health_checks.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sentinel-health
